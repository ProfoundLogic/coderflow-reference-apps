# Copy this file to .env and fill in your values.
# Real environment variables take precedence over anything set here.

# Work library to build into (required). Its contents are destroyed and rebuilt.
IBMI_BUILD_LIBRARY=

# GitHub token with write access to ProfoundLogic/coderflow-reference-apps.
# Required only when running with --publish. GH_TOKEN also works.
GITHUB_TOKEN=

# --- Unix-like (Linux/macOS) remote builds only --------------------------
# On IBM i these are ignored (the build runs locally). Off IBM i, codermake
# and the direct IBM i build steps connect to the host over SSH.
#IBMI_HOST=ibmi.example.com
#IBMI_USER=devuser
# Path to an SSH private key (optional). If unset, the system SSH configuration
# determines the key, mirroring codermake.
#IBMI_KEY=/path/to/ssh/key
