{
  "name": "ibmi",
  "description": "IBM i agentic coding examples",
  "image_name": "ibmi",
  "default_agent": "claude",
  "repos": [
    {
      "name": "coderflow-reference-apps",
      "url": "https://github.com/ProfoundLogic/coderflow-reference-apps",
      "branch": "main",
      "allow_branch_selection": true,
      "clone_auto": true,
      "ibmiImportEnabled": true
    }
  ],
  "external_connections": [
    {
      "name": "dev",
      "type": "ibmi",
      "description": "IBM i Development Server",
      "available_for": [
        "tasks"
      ],
      "config": {
        "features": [
          "sql",
          "build",
          "interactive",
          "ssh",
          "sync",
          "ejs-display-files"
        ],
        "sync_credentials": "prompt",
        "build_library_prefix": "AITSK"
      }
    }
  ],
  "standardInstructions": {
    "outputRequirements": true,
    "screenshotGuidelines": false,
    "ibmiOutputRequirements": true,
    "ibmiExploratoryVerification": true,
    "ibmiDatabaseSql": true
  },
  "memory": {
    "enabled": true
  },
  "deployment_profile_order": [
    "build-and-promote"
  ],
  "tasks": {
    "defaultShared": true
  },
  "setup": {
    "version": 1,
    "title": "Finish setting up IBM i",
    "steps": [
      {
        "id": "set-up-repository",
        "title": "Set up your project repository",
        "body": "Open the Repositories tab and add a new, empty repository (initialized with a default branch) for this environment to build from.",
        "action": {
          "type": "navigate",
          "label": "Open the Repositories tab",
          "config": { "tab": "repos" }
        },
        "docsLabel": "Full Guide",
        "docs": "/docs/ibmi/reference-app/set-up-repository"
      },
      {
        "id": "configure-connection",
        "title": "Fill in the IBM i connection",
        "body": "Open the Connections tab, fill in the dev connection, set its build repository to your repo, and build the environment.",
        "action": {
          "type": "navigate",
          "label": "Open the Connections tab",
          "config": { "tab": "connections", "connection": "dev" }
        },
        "docsLabel": "Full Guide",
        "docs": "/docs/ibmi/reference-app/configure-connection"
      },
      {
        "id": "copy-example-source",
        "title": "Copy in the example source",
        "body": "Run a task to copy the example source into your repository, then detach the reference-apps repo.",
        "docsLabel": "Full Guide",
        "docs": "/docs/ibmi/reference-app/copy-example-source"
      },
      {
        "id": "install-base-library",
        "title": "Install the CFDEMO base library",
        "body": "Restore the CFDEMO base library onto your IBM i — with the installer, or by hand.",
        "action": {
          "type": "ibmi-savf-install",
          "config": {
            "source": {
              "kind": "github-release",
              "repo": "ProfoundLogic/coderflow-reference-apps",
              "tagPrefix": "ibmi/",
              "asset": "cfdemo.savf"
            },
            "defaultLibrary": "CFDEMO",
            "savfLibrary": "QTEMP",
            "libraryText": "CoderFlow Example Base Library",
            "commands": [
              "RSTOBJ OBJ(*ALL) SAVLIB({SAVLIB}) DEV(*SAVF) SAVF({LIB}/{SAVF}) RSTLIB({LIB})",
              "QSYS/DLTF FILE({LIB}/{SAVF})"
            ]
          }
        },
        "docsLabel": "Open the manual install guide",
        "docs": "/docs/ibmi/reference-app/install-base-library"
      }
    ]
  }
}
